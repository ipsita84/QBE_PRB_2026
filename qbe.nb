Cell[BoxData[{
 RowBox[{
  RowBox[{"FR", "[", "a_", "]"}], ":=", 
  RowBox[{
   FractionBox["1", "Pi"], 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"2", "Pi"}]], 
      RowBox[{"ArcTan", "[", 
       FractionBox["a", 
        RowBox[{"2", " ", 
         SuperscriptBox[
          RowBox[{"Sin", "[", 
           FractionBox["\[Theta]", "2"], "]"}], "3"]}]], "]"}], 
      RowBox[{"Sin", "[", 
       FractionBox["\[Theta]", "2"], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", "0", ",", 
       RowBox[{"2", "Pi"}]}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FI", "[", "a_", "]"}], ":=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", "Pi"}]], 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{
       FractionBox["1", 
        RowBox[{"2", "Pi"}]], 
       RowBox[{"Log", "[", 
        RowBox[{"1", "+", 
         FractionBox[
          SuperscriptBox["a", "2"], 
          RowBox[{" ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", 
             FractionBox["\[Theta]", "2"], "]"}], "6"]}]]}], "]"}], 
       RowBox[{"Sin", "[", 
        FractionBox["\[Theta]", "2"], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "0", ",", 
        RowBox[{"2", "Pi"}]}], "}"}]}], "]"}]}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.952791477821138*^9, 3.9527915941262617`*^9}, {
