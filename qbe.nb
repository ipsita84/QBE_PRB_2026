Cell[BoxData[{
 RowBox[{
  RowBox[{"fermi", "[", 
   RowBox[{"\[Omega]_", ",", "T_"}], "]"}], ":=", 
  FractionBox["1", 
   RowBox[{
    RowBox[{"Exp", "[", 
     FractionBox["\[Omega]", "T"], "]"}], "+", 
    "1"}]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"correction", "[", 
   RowBox[{"\[Omega]p_", ",", "\[Omega]_", ",", "T_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"fermi", "[", 
    RowBox[{
     RowBox[{"\[Omega]p", "+", "\[Omega]"}], ",", "T"}], "]"}], "+", 
   RowBox[{"fermi", "[", 
    RowBox[{
     RowBox[{"\[Omega]p", "-", "\[Omega]"}], ",", "T"}], "]"}], "-", 
   RowBox[{"2", " ", 
    RowBox[{"fermi", "[", 
     RowBox[{"\[Omega]p", ",", "T"}], "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"correctionint", "[", 
   RowBox[{"\[Omega]_", ",", "T_"}], "]"}], ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"fermi", "[", 
      RowBox[{
       RowBox[{"\[Omega]p", "+", "\[Omega]"}], ",", "T"}], "]"}], "+", 
     RowBox[{"fermi", "[", 
      RowBox[{
       RowBox[{"\[Omega]p", "-", "\[Omega]"}], ",", "T"}], "]"}], "-", 
     RowBox[{"2", " ", 
      RowBox[{"fermi", "[", 
       RowBox[{"\[Omega]p", ",", "T"}], "]"}]}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Omega]p", ",", 
      RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}]}], 
   "]"}]}]}], "Input",
