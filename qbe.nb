Cell[BoxData[{
 RowBox[{
  RowBox[{"DR", "[", 
   RowBox[{"\[Omega]_", ",", "q_", ",", "\[Chi]_"}], "]"}], ":=", 
  FractionBox["1", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"\[Omega]", "+", 
       RowBox[{"I", "*", ".000001"}]}], ")"}], "2"], "-", 
    SuperscriptBox["q", "2"], "+", 
    RowBox[{"I", " ", "\[Chi]", " ", 
     FractionBox["\[Omega]", "q"]}]}]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DRFull", "[", 
   RowBox[{"\[Omega]_", ",", "q_", ",", "\[Chi]_"}], "]"}], ":=", 
  FractionBox["1", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"\[Omega]", "+", 
       RowBox[{"I", "*", ".000001"}]}], ")"}], "2"], "-", 
    SuperscriptBox["q", "2"], "+", 
    RowBox[{"I", " ", "\[Chi]", " ", 
     FractionBox["\[Omega]", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        SuperscriptBox["q", "2"], "-", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"\[Omega]", "+", 
           RowBox[{"I", "*", ".00001"}]}], ")"}], "2"]}], 
       "]"}]]}]}]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DR0", "[", 
   RowBox[{"\[Omega]_", ",", "q_", ",", "\[Chi]_"}], "]"}], ":=", 
  FractionBox["1", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["q", "2"]}], "+", 
    RowBox[{"I", " ", "\[Chi]", " ", 
     FractionBox["\[Omega]", "q"]}]}]]}]}], "Input",
 CellChangeTimes->{{3.934027430173198*^9, 3.9340274828152933`*^9}, {
