   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"th", "=", "0.005"}], ";", 
  RowBox[{
   RowBox[{"plz", "[", 
    RowBox[{"kf_", ",", "\[Alpha]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r1", ",", "r2", ",", "f2", ",", "barom", ",", 
       RowBox[{"qbar", "=", "0.01"}], ",", "rem", ",", "utheta", ",", "om", ",", 
       RowBox[{"alpha", "=", "\[Alpha]"}], ",", "check"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"om", "=", 
       RowBox[{
        RowBox[{"FindRoot", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"zeromode", "[", 
            RowBox[{"barom", ",", "qbar", ",", "alpha"}], "]"}], "==", "0"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"barom", ",", "0.1"}], "}"}]}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"check", "=", 
       RowBox[{
        RowBox[{"F0", "[", 
         RowBox[{"om", ",", "alpha"}], "]"}], "+", "om"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"r1", "=", 
       RowBox[{"rm", "[", 
        RowBox[{"om", ",", "qbar", ",", "alpha"}], "]"}]}], ";", 
      RowBox[{"r2", "=", 
       RowBox[{"rp", "[", 
        RowBox[{"om", ",", "qbar", ",", "alpha"}], "]"}]}], ";", 
      RowBox[{"f2", "=", 
       RowBox[{"f", "[", 
        RowBox[{"om", ",", "qbar", ",", "alpha", ",", "r2"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"rem", "=", 
       RowBox[{"renormzero", "[", 
        RowBox[{"om", ",", "qbar", ",", "alpha"}], "]"}]}], ";", 
      "\[IndentingNewLine]", " ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"check", ">", "qbar"}], 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{"is", " ", "s", " ", "\[Eta]"}], " ", ">", " ", 
          RowBox[{"1", " ", "?"}]}], " ", "*)"}], ",", 
        RowBox[{"PolarPlot", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"kf", ",", 
            RowBox[{"kf", "-", "0.75", "+", 
             RowBox[{"rem", 
              RowBox[{"(", 
               RowBox[{"1", "-", 
                RowBox[{"2", "*", 
                 RowBox[{"Sum", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"Cos", "[", 
                    RowBox[{"l", " ", "\[Theta]"}], "]"}], 
                    RowBox[{"(", 
                    RowBox[{
                    FractionBox["1", 
                    RowBox[{"r2", "-", "r1"}]], 
                    FractionBox["f2", 
                    SuperscriptBox["r2", 
                    RowBox[{"l", "+", "1"}]]]}], ")"}]}], ",", 
                   RowBox[{"{", 
                    RowBox[{"l", ",", "1", ",", 
                    SuperscriptBox["10", "3"]}], "}"}]}], "]"}]}]}], 
               ")"}]}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Theta]", ",", "0", ",", 
            RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
          RowBox[{"PlotRange", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{"All", ",", "All"}], "}"}]}], ",", 
