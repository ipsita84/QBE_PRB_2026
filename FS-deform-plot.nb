 RowBox[{
  RowBox[{
   RowBox[{"renorm", "[", 
    RowBox[{"\[CapitalOmega]_", ",", "q_", ",", "\[Alpha]_"}], "]"}], ":=", 
   FractionBox["1", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", 
       RowBox[{"Sum", "[", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"Abs", "[", 
