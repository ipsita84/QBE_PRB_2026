Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"FR", "[", 
    RowBox[{"\[Theta]_", ",", "a_"}], "]"}], "=", 
   RowBox[{
    FractionBox["2", "Pi"], " ", 
    RowBox[{"ArcTan", "[", 
     FractionBox["a", 
      RowBox[{"2", " ", 
       SuperscriptBox[
        RowBox[{"Sin", "[", 
         FractionBox["\[Theta]", "2"], "]"}], "3"]}]], "]"}], 
    RowBox[{"Sin", "[", 
     FractionBox["\[Theta]", "2"], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FRl", "[", 
    RowBox[{"l_", ",", "a_"}], "]"}], ":=", 
   RowBox[{
    FractionBox["1", "Pi"], 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"FR", "[", 
        RowBox[{"\[Theta]", ",", "a"}], "]"}], 
       RowBox[{"Cos", "[", 
        RowBox[{"l", "*", "\[Theta]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "0", ",", "Pi"}], "}"}], ",", 
      RowBox[{"MaxRecursion", "\[Rule]", "10"}], ",", 
      RowBox[{"PrecisionGoal", "\[Rule]", "5"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"F0", "[", 
    RowBox[{"\[CapitalOmega]_", ",", "\[Alpha]_"}], "]"}], "=", 
   FractionBox[
    RowBox[{"4", "-", 
     FractionBox[
      RowBox[{"3", " ", 
       RowBox[{"HypergeometricPFQ", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           FractionBox["1", "2"], ",", 
           FractionBox["5", "6"], ",", 
           FractionBox["7", "6"]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           FractionBox["4", "3"], ",", 
           FractionBox["5", "3"]}], "}"}], ",", 
         RowBox[{"-", 
          FractionBox["4", 
           RowBox[{
            SuperscriptBox["\[CapitalOmega]", "2"], 
            SuperscriptBox["\[Alpha]", "2"]}]]}]}], "]"}]}], 
      RowBox[{"\[CapitalOmega]", " ", "\[Alpha]"}]]}], 
    RowBox[{"2", " ", "\[Pi]"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"\[CapitalOmega]_", ",", "q_", ",", "\[Alpha]_", ",", "r_"}], 
    "]"}], "=", 
   RowBox[{"1", "-", 
    RowBox[{
     FractionBox["\[CapitalOmega]", "q"], "r", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       FractionBox[
        RowBox[{"2", 
         RowBox[{"F0", "[", 
          RowBox[{"\[CapitalOmega]", ",", "\[Alpha]"}], "]"}]}], "q"]}], 
      ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fm", "[", 
    RowBox[{"\[CapitalOmega]_", ",", "q_", ",", "\[Alpha]_", ",", "r_"}], 
    "]"}], ":=", 
   RowBox[{"r", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"2", 
       FractionBox[
        RowBox[{"FRl", "[", 
         RowBox[{"1", ",", 
          RowBox[{"\[CapitalOmega]", "*", "\[Alpha]"}]}], "]"}], "q"], 
       "r"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rp", "[", 
    RowBox[{"\[CapitalOmega]_", ",", "q_", ",", "\[Alpha]_"}], "]"}], "=", 
   FractionBox[
    RowBox[{"\[CapitalOmega]", "+", 
     RowBox[{"F0", "[", 
      RowBox[{"\[CapitalOmega]", ",", "\[Alpha]"}], "]"}], "+", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"\[CapitalOmega]", "+", 
          RowBox[{"F0", "[", 
           RowBox[{"\[CapitalOmega]", ",", "\[Alpha]"}], "]"}]}], ")"}], "2"],
        "-", 
       SuperscriptBox["q", "2"]}], "]"}]}], "q"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rm", "[", 
    RowBox[{"\[CapitalOmega]_", ",", "q_", ",", "\[Alpha]_"}], "]"}], "=", 
   FractionBox[
    RowBox[{"\[CapitalOmega]", "+", 
     RowBox[{"F0", "[", 
      RowBox[{"\[CapitalOmega]", ",", "\[Alpha]"}], "]"}], "-", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"\[CapitalOmega]", "+", 
          RowBox[{"F0", "[", 
           RowBox[{"\[CapitalOmega]", ",", "\[Alpha]"}], "]"}]}], ")"}], "2"],
        "-", 
       SuperscriptBox["q", "2"]}], "]"}]}], "q"]}], ";"}], 
"\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"urenoml", "[", 
   RowBox[{"l_", ",", "\[CapitalOmega]_", ",", "q_", ",", "\[Alpha]_"}], 
   "]"}], ":=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{
     RowBox[{"rp", "[", 
      RowBox[{"\[CapitalOmega]", ",", "q", ",", "\[Alpha]"}], "]"}], "-", 
     RowBox[{"rm", "[", 
      RowBox[{"\[CapitalOmega]", ",", "q", ",", "\[Alpha]"}], "]"}]}]], 
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{"f", "[", 
       RowBox[{"\[CapitalOmega]", ",", "q", ",", "\[Alpha]", ",", 
